#theme = NightOwlDark
theme = dark:NightOwlDark,light:NightOwlLight
font-size = 14
font-family = Monaspace Argon
font-feature = "ss01"
# ss02: <= and >=
font-feature = "ss02"
# ss03: -> and ~>
font-feature = "ss03"
